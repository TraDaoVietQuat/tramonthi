# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# database (contains real user data, never commit)
*.db
*.db-journal

# production build flag (generated by DONG_GOI.bat, do not commit)
PRODUCTION_BUILD

# Auto-setup flag (generated by KHOI_DONG.bat, do not commit)
.setup_done

# Portable Node.js (auto-downloaded by KHOI_DONG.bat, do not commit)
runtime/

# typescript
*.tsbuildinfo
next-env.d.ts
